# ── Postgres ──────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=jobdb
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/jobdb

# ── GCP / Vertex AI ──────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
VERTEX_AI_LOCATION=us-central1
EMBEDDING_MODEL=text-embedding-004

# ── Pub/Sub (Job Discovery Service) ───────────────────────
PUBSUB_SUBSCRIPTION=user-refresh-requested-sub
PUBSUB_TOPIC_MATCHES=matches-calculated

# ── Pub/Sub (User Service) ───────────────────────────────
PUBSUB_TOPIC_REFRESH=user-refresh-requested
PUBSUB_SUBSCRIPTION_MATCHES=matches-calculated-sub

# ── JSearch (RapidAPI) ────────────────────────────────────
RAPIDAPI_KEY=your-rapidapi-key
JSEARCH_QUERY=software engineer in United States
JSEARCH_DATE_POSTED=3days
JSEARCH_NUM_PAGES=1

# ── Internal auth ─────────────────────────────────────────
INTERNAL_API_KEY=changeme

DEV_MODE=true
